# Копирай този файл като backend/.env и попълни стойностите.
# .env е в .gitignore и НИКОГА не влиза в git.

# --- ЗАДЪЛЖИТЕЛНО ---
# Генерирай уникален ключ с:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# --- JWT (по избор, имат разумни стойности по подразбиране) ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Фронтенд origin за CORS (точен адрес, без "*") ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Cookies: в production зад HTTPS сложи COOKIE_SECURE=true ---
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Път до базата (по избор) ---
# BOOKSPACE_DB=/path/to/bookspace.db

# --- SMTP тайни (стоят само на сървъра, не стигат браузъра) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
